<!DOCTYPE html>
<html>
<head>
    <title>Vinyl Board Game Demo</title>
    <style>
        #board { display: flex; gap: 10px; margin-bottom: 20px; }
        .space { width: 60px; height: 60px; border: 2px solid #333; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; }
        .joy { background-color: #e6fffa; border-color: #38b2ac; }
        .fear { background-color: #fff5f5; border-color: #f56565; }
        .player { width: 15px; height: 15px; border-radius: 50%; margin: 2px; }
        #p1 { background: blue; }
        #p2 { background: red; }
    </style>
</head>
<body>

    <h2>Board Game Demo</h2>
    <div id="board">
        </div>

    <button onclick="playTurn()">Roll Die (Player <span id="turn">1</span>)</button>
    <p id="status">Roll to start!</p>

    <script>
        const boardLayout = ["Start", "", "Joy", "", "Fear", "", "Joy", "", "Fear", "Finish"];
        let positions = [0, 0]; // Player 1 and Player 2 at space 0
        let currentPlayer = 0;

        function initBoard() {
            const boardDiv = document.getElementById('board');
            boardDiv.innerHTML = '';
            boardLayout.forEach((type, i) => {
                const div = document.createElement('div');
                div.className = `space ${type.toLowerCase()}`;
                div.innerHTML = `<span>${i}</span><small>${type}</small><div id="space-${i}"></div>`;
                boardDiv.appendChild(div);
            });
            updatePieces();
        }

        function updatePieces() {
            // Clear all spaces
            for(let i=0; i<10; i++) document.getElementById(`space-${i}`).innerHTML = '';
            // Place players
            positions.forEach((pos, i) => {
                const p = document.createElement('div');
                p.className = 'player';
                p.id = `p${i+1}`;
                document.getElementById(`space-${pos}`).appendChild(p);
            });
        }

        function playTurn() {
            const roll = Math.floor(Math.random() * 6) + 1;
            let pos = positions[currentPlayer] + roll;

            // Boundary check
            if (pos >= 9) pos = 9;

            // Apply "If-Then" Rules
            let message = `Player ${currentPlayer + 1} rolled a ${roll}.`;
            if (boardLayout[pos] === "Joy") {
                pos += 1;
                message += " Hit JOY! Move forward 1.";
            } else if (boardLayout[pos] === "Fear") {
                pos -= 1;
                message += " Hit FEAR! Move back 1.";
            }

            positions[currentPlayer] = Math.max(0, pos);
            document.getElementById('status').innerText = message;
            
            updatePieces();

            if (positions[currentPlayer] === 9) {
                alert(`Player ${currentPlayer + 1} wins!`);
                positions = [0, 0];
                initBoard();
            }

            currentPlayer = currentPlayer === 0 ? 1 : 0;
            document.getElementById('turn').innerText = currentPlayer + 1;
        }

        initBoard();
    </script>
</body>
</html>
